# Copie este arquivo para .env e preencha com seus valores reais.
# O .env está no .gitignore — NUNCA comite chaves de verdade.

# Chave de API do RunPod (Settings -> API Keys no painel do RunPod).
RUNPOD_API_KEY=

# ID do endpoint serverless (aparece na página do endpoint no painel do RunPod).
RUNPOD_ENDPOINT_ID=
